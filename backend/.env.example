# NEXUS AI - Environment Configuration
# Copy this file to .env and fill in your values

# ========================
# Core Settings
# ========================
NEXUS_APP_NAME=NEXUS AI
NEXUS_VERSION=1.0.0
NEXUS_ENV=development
NEXUS_DEBUG=true
NEXUS_SECRET_KEY=your-secret-key-change-this-in-production
NEXUS_HOST=0.0.0.0
NEXUS_PORT=8000

# ========================
# Database
# ========================
NEXUS_DB_PATH=./data/nexus.db
NEXUS_VECTOR_DB_PATH=./data/chromadb
NEXUS_BACKUP_PATH=./data/backups

# ========================
# AI Models (Ollama)
# ========================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=llava

# ========================
# Voice Settings
# ========================
VOICE_TTS_MODEL=tts_models/en/ljspeech/tacotron2-DDC
VOICE_STT_MODEL=base
VOICE_WAKE_WORD=nexus
VOICE_LANGUAGE=en

# ========================
# Home Automation (MQTT)
# ========================
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_USERNAME=nexus
MQTT_PASSWORD=nexus_mqtt_password
MQTT_TOPIC_PREFIX=nexus/home

# ========================
# Email Settings
# ========================
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993

# ========================
# Notification Settings
# ========================
NOTIFICATION_ENABLED=true
NOTIFICATION_SOUND=true
NOTIFICATION_DESKTOP=true

# ========================
# Scheduler Settings
# ========================
TRAINING_SCHEDULE_HOUR=3
TRAINING_SCHEDULE_MINUTE=0
BACKUP_SCHEDULE_HOUR=2
BACKUP_SCHEDULE_MINUTE=0

# ========================
# Logging
# ========================
LOG_LEVEL=DEBUG
LOG_FILE_PATH=./logs/nexus.log
LOG_MAX_SIZE=10MB
LOG_ROTATION=1 day
LOG_RETENTION=30 days

# ========================
# User Profile
# ========================
USER_NAME=User
USER_TIMEZONE=UTC
USER_LANGUAGE=en
